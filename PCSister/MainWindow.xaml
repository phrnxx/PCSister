<Window x:Class="PCSister.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCSister" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        Topmost="True" 
        ShowInTaskbar="False"
        Loaded="Window_Loaded">

    <Canvas x:Name="MainCanvas" IsHitTestVisible="False">
        <Image x:Name="PetImage" Width="128" Height="128" Stretch="Fill" 
               RenderTransformOrigin="0.5,0.5" IsHitTestVisible="True"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               RenderOptions.EdgeMode="Aliased"
               MouseLeftButtonDown="PetImage_MouseLeftButtonDown"
               MouseRightButtonUp="PetImage_MouseRightButtonUp">
            <Image.RenderTransform>
                <ScaleTransform x:Name="PetTransform" ScaleX="2" ScaleY="2"/>
            </Image.RenderTransform>

            <Image.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="MenuFocus" Header="Режим фокусу: ВИМК" Click="MenuFocus_Click"/>
                    <Separator/>
                    <MenuItem Header="Вихід" Click="MenuExit_Click"/>
                </ContextMenu>
            </Image.ContextMenu>
        </Image>

        <Border x:Name="SpeechBubble" Background="White" BorderBrush="Black" BorderThickness="2" 
                CornerRadius="8" Padding="10,5" Visibility="Hidden" MaxWidth="250">
            <TextBlock x:Name="SpeechText" Text="Привіт!" FontFamily="Consolas" FontSize="14" 
                       TextWrapping="Wrap" Foreground="Black" FontWeight="Bold"/>
        </Border>
    </Canvas>
</Window>